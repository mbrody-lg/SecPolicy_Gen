FLASK_ENV=development
FLASK_RUN_DEBUG=0
DEBUG=false
FLASK_SECRET_KEY=fake-local-context-flask-secret
MONGO_URI=mongodb://mongo:27017/contextdb
OPENAI_API_KEY=fake-local-context-openai-key
OPENAI_API_URL=https://api.openai.com/v1/
POLICY_AGENT_URL=http://policy-agent:5000
VALIDATOR_AGENT_URL=http://validator-agent:5000
POLICY_AGENT_TIMEOUT_SECONDS=30
VALIDATOR_AGENT_TIMEOUT_SECONDS=30
MAX_CONTENT_LENGTH=262144
SESSION_COOKIE_SECURE=false
TRUSTED_HOSTS=localhost,context-agent
CONTEXT_IMPORT_PATH=/context-agent/app/config/examples/answers
