FLASK_ENV=development
DEBUG=false
TESTING=false
FLASK_SECRET_KEY=fake-local-flask-secret

MONGO_URI=mongodb://mongo:27017/contextdb
POLICY_AGENT_URL=http://policy-agent:5000
VALIDATOR_AGENT_URL=http://validator-agent:5000
POLICY_AGENT_TIMEOUT_SECONDS=30
VALIDATOR_AGENT_TIMEOUT_SECONDS=30

OPENAI_API_KEY=fake-local-openai-key
OPENAI_API_URL=https://api.openai.com/v1/
MISTRAL_API_KEY=fake-local-mistral-key
MISTRAL_API_URL=https://api.mistral.ai/v1

CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_READINESS_MODE=live
RAG_VALIDATE_CHROMA=false
POLICY_AGENT_ALLOW_MODEL_DOWNLOAD=0

MAX_CONTENT_LENGTH=262144
SESSION_COOKIE_SECURE=false
TRUSTED_HOSTS=localhost,context-agent,policy-agent,validator-agent
