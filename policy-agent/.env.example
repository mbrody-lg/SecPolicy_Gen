FLASK_ENV=development
FLASK_RUN_DEBUG=0
DEBUG=false
FLASK_SECRET_KEY=fake-local-policy-flask-secret
MONGO_URI=mongodb://mongo:27017/policydb
OPENAI_API_URL=https://api.openai.com/v1/
OPENAI_API_KEY=fake-local-policy-openai-key
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_READINESS_MODE=config_only
RAG_SOURCES_PATH=app/config/rag_sources.yaml
RAG_VALIDATE_CHROMA=false
CONFIG_PATH=/policy-agent/app/config/policy_agent.yaml
MAX_CONTENT_LENGTH=262144
SESSION_COOKIE_SECURE=false
TRUSTED_HOSTS=localhost,policy-agent
POLICY_AGENT_ALLOW_MODEL_DOWNLOAD=0
